{
  "info": {
    "name": "TradePilot ATS",
    "description": "Manual webhook triggers and trade execution tests for TradePilot ATS.\n\nSetup:\n1. Set the `base_url` variable to your ATS URL\n2. Login first to get a JWT token (stored automatically)\n3. Use the webhook calls to trigger signals",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",        "value": "https://ats.tradepilotlabs.com" },
    { "key": "daily_secret",    "value": "34d88237c1b7ad922fd3bcd299f1bb13f33d2bbc4297734f" },
    { "key": "custom_secret",   "value": "3499d4fe70a757259017487fdae2881ed47c6d42b539aa23" },
    { "key": "jwt_token",       "value": "" },
    { "key": "admin_email",     "value": "pshridev28@gmail.com" },
    { "key": "admin_password",  "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login (get JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.token) {",
                  "  pm.collectionVariables.set('jwt_token', r.token);",
                  "  console.log('Token saved:', r.token.slice(0,30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🚀 Webhooks — Trigger Signals",
      "item": [
        {
          "name": "SPY CALL (ORB-15 format)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/webhook/strategy/daily-trend?secret={{daily_secret}}",
              "host": ["{{base_url}}"],
              "path": ["webhook", "strategy", "daily-trend"],
              "query": [{ "key": "secret", "value": "{{daily_secret}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"timestamp\": \"2026-04-30T10:30:00-0400\",\n  \"unmodifiedTicker\": \"SPY260430C715.0\",\n  \"suggestedOption\": \"SPY 04/30 715c\",\n  \"action\": \"open\",\n  \"direction\": \"calls\",\n  \"source\": \"tradepilot-orb15\",\n  \"price\": 714.50,\n  \"volume\": 45000,\n  \"stopLossPct\": 50,\n  \"orbHigh\": 714.80,\n  \"rsi\": 62.5\n}"
            },
            "description": "Triggers a SPY call signal in ORB-15 format. Adjust the strike in unmodifiedTicker and price to match current market."
          }
        },
        {
          "name": "SPY PUT (ORB-15 format)",

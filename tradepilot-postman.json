    },
    {
      "name": "📊 Positions & Trades",
      "item": [
        {
          "name": "Get open positions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/api/positions",
            "description": "Returns all currently open positions being monitored."
          }
        },
        {
          "name": "Get trade history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/api/trades",
            "description": "Returns closed trade history."
          }
        },
        {
          "name": "Get today stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/api/stats",
            "description": "Today's P&L, trade count, win rate."
          }
        },
        {
          "name": "🚨 Flatten All (emergency close)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/flatten-all",
            "body": { "mode": "raw", "raw": "{}" },
            "description": "Emergency: closes ALL open positions immediately at market price."
          }
        }
      ]
    },
    {
      "name": "⚙️ Settings",
      "item": [
        {
          "name": "Get settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/api/settings"
          }
        },
        {
          "name": "Update settings",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/settings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trading_enabled\": true,\n  \"max_trades_per_day\": 1,\n  \"max_capital_per_trade\": 200,\n  \"stop_loss_pct\": 50,\n  \"max_contract_cost\": 2.00,\n  \"min_contract_cost\": 0.10\n}"
            },
            "description": "Update risk settings. Adjust max_capital_per_trade, stop_loss_pct, etc."
          }
        },
        {
          "name": "Enable trading",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/settings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trading_enabled\": true\n}"
            }
          }
        },
        {
          "name": "Disable trading",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/api/settings",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trading_enabled\": false\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🛠 Admin",
      "item": [
        {
          "name": "Admin overview",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/admin/overview"
          }
        },
        {
          "name": "Webhook signal log",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": {
              "raw": "{{base_url}}/admin/webhook-signals?limit=20",
              "host": ["{{base_url}}"],
              "path": ["admin", "webhook-signals"],
              "query": [{ "key": "limit", "value": "20" }]
            },
            "description": "Shows the last 20 webhook signals received (all strategies)."
          }
        },
        {
          "name": "Check Polygon.io",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
            "url": "{{base_url}}/admin/polygon-check",
            "description": "Verifies Polygon.io API key is working and returns plan tier."
          }
        },
        {
          "name": "Fire test signal (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/admin/strategies/daily-trend/fire",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payload\": {\n    \"action\": \"open\",\n    \"direction\": \"calls\",\n    \"unmodifiedTicker\": \"SPY260430C715.0\",\n    \"price\": 714.50,\n    \"stopLossPct\": 50,\n    \"source\": \"manual-test\"\n  }\n}"
            },
            "description": "Fires a test signal through the strategy router (requires admin JWT). Same as a real webhook but authenticated via JWT instead of secret."
          }
        }
      ]
    }
  ]
}

              "raw": "{\n  \"timestamp\": \"2026-04-30T10:45:00-0400\",\n  \"unmodifiedTicker\": \"SPY260430P710.0\",\n  \"suggestedOption\": \"SPY 04/30 710p\",\n  \"action\": \"open\",\n  \"direction\": \"puts\",\n  \"source\": \"tradepilot-orb15\",\n  \"price\": 710.20,\n  \"volume\": 38000,\n  \"stopLossPct\": 50,\n  \"orbLow\": 710.50,\n  \"rsi\": 34.2\n}"
            },

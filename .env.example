# ─── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Heroku Postgres) ──────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/tradepilot

# ─── Redis (RedisCloud) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Auth ────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d

# ─── TastyTrade OAuth ────────────────────────────────────
TASTY_CLIENT_ID=your_tastytrade_client_id
TASTY_CLIENT_SECRET=your_tastytrade_client_secret
TASTY_REDIRECT_URI=http://localhost:3000/auth/tastytrade/callback
# Production: https://ats.tradepilot.io/auth/tastytrade/callback

# ─── Dashboard (CORS origin) ─────────────────────────────
DASHBOARD_URL=http://localhost:5173
# Production: https://app.tradepilot.io

# ─── TradePilot internal API key (dashboard → ATS calls) ─
TRADEPILOT_API_KEY=replace_with_random_string
